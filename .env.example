# Database
DB_USER=planning
DB_PASSWORD=planning

# API
NODE_ENV=production
PORT=3000

# Generated DATABASE_URL (used inside containers — do not set manually):
# DATABASE_URL=postgres://planning:planning@db:5432/pi_planning

# Event Store
EVENT_STORE_MODE=audit          # audit | source

# MediatorFlow (optional telemetry dashboard)
MEDIATOR_FLOW_ENABLED=false
MEDIATOR_FLOW_URL=http://localhost:4800
MEDIATOR_FLOW_SERVICE_NAME=pi-planning
